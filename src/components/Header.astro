---
import { CATEGORIES, CATEGORY_LABELS } from '../lib/categories';
import { SITE } from '../lib/site';

const path = Astro.url.pathname;
---

<header class="sticky top-0 z-20 border-b border-neutral-200 bg-white/90 backdrop-blur dark:border-neutral-800 dark:bg-neutral-950/90">
  <div class="mx-auto flex max-w-3xl items-center justify-between gap-3 px-4 py-3">
    <a href="/" class="flex items-center gap-2 font-serif text-xl font-bold tracking-tight">
      <span class="inline-block h-5 w-5 rounded-full bg-sky-600"></span>
      {SITE.name}
    </a>

    <button
      id="theme-toggle"
      type="button"
      aria-label="Alternar tema claro/escuro"
      class="rounded-md p-2 text-neutral-500 hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100"
    >
      <svg class="h-5 w-5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
      </svg>
      <svg class="hidden h-5 w-5 dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
      </svg>
    </button>
  </div>

  <nav aria-label="Categorias" class="mx-auto max-w-3xl overflow-x-auto px-4 pb-2">
    <ul class="flex gap-1 whitespace-nowrap text-sm">
      {
        CATEGORIES.map((cat) => {
          const active = path === `/${cat}` || path === `/${cat}/`;
          return (
            <li>
              <a
                href={`/${cat}`}
                class:list={[
                  'inline-block rounded-full px-3 py-1 transition-colors',
                  active
                    ? 'bg-sky-600 text-white'
                    : 'text-neutral-600 hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-800',
                ]}
              >
                {CATEGORY_LABELS[cat]}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const dark = document.documentElement.classList.toggle('dark');
    try {
      localStorage.setItem('tema', dark ? 'dark' : 'light');
    } catch (_) {}
  });
</script>
