---
// Inscrição na newsletter via Buttondown (plano grátis). Só aparece quando
// NEWSLETTER.buttondownUser está preenchido (ver src/lib/site.ts).
import { NEWSLETTER, SITE } from '../lib/site';

const user = NEWSLETTER.buttondownUser;
const action = `https://buttondown.com/api/emails/embed-subscribe/${user}`;
---

{
  user && (
    <section class="mt-10 rounded-lg border border-neutral-200 bg-neutral-50 p-5 dark:border-neutral-800 dark:bg-neutral-900">
      <h2 class="font-serif text-lg font-bold">Receba as notícias por e-mail</h2>
      <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">
        Um resumo do que importou, direto na sua caixa de entrada. Grátis, cancele quando quiser.
      </p>
      <form
        action={action}
        method="post"
        target="popupwindow"
        onsubmit={`window.open('https://buttondown.com/${user}', 'popupwindow')`}
        class="mt-3 flex flex-col gap-2 sm:flex-row"
      >
        <label class="sr-only" for="bd-email">Seu e-mail</label>
        <input
          id="bd-email"
          type="email"
          name="email"
          required
          placeholder="seu@email.com"
          class="w-full flex-1 rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 placeholder:text-neutral-400 focus:border-sky-500 focus:outline-none dark:border-neutral-700 dark:bg-neutral-950 dark:text-neutral-100"
        />
        <button
          type="submit"
          class="rounded-md bg-sky-600 px-4 py-2 text-sm font-medium text-white hover:bg-sky-700"
        >
          Inscrever
        </button>
      </form>
      <p class="mt-2 text-xs text-neutral-400">{SITE.name} não compartilha seu e-mail.</p>
    </section>
  )
}
