---
import Layout from '../layouts/Layout.astro';
import StoryList from '../components/StoryList.astro';
import CategorySection from '../components/CategorySection.astro';
import AdSlot from '../components/AdSlot.astro';
import Newsletter from '../components/Newsletter.astro';
import { currentEdition, hasContent } from '../lib/data';
import { latestEditorial } from '../lib/editorial';
import { CATEGORIES } from '../lib/categories';
import { topics } from '../lib/topics';
import { formatDateFull } from '../lib/format';
import { SITE } from '../lib/site';
import { itemListJsonLd, websiteJsonLd } from '../lib/seo';

const edition = currentEdition;
const filled = hasContent(edition);
const hotTopics = topics.filter((t) => t.indexable).slice(0, 24);
const siteUrl = new URL('/', Astro.site!).href;
const pageUrl = new URL(Astro.url.pathname, Astro.site!).href;
const jsonLd = [websiteJsonLd(siteUrl), itemListJsonLd(edition.home, pageUrl)];
const ogImage = edition.home.find((s) => s.imageUrl)?.imageUrl;
---

<Layout image={ogImage} jsonLd={jsonLd}>
  <header class="flex items-center gap-4">
    <img src="/logo.png" alt="" width="64" height="64" class="h-14 w-14 shrink-0 sm:h-16 sm:w-16" />
    <div>
      <h1 class="font-serif text-3xl font-bold tracking-tight">{SITE.name}</h1>
      <p class="mt-1 text-neutral-600 dark:text-neutral-400">{SITE.tagline}</p>
      {filled && <p class="mt-1 text-sm text-neutral-500">Edição de {formatDateFull(edition.date)}</p>}
    </div>
  </header>

  {
    !filled ? (
      <p class="py-16 text-center text-neutral-500">A primeira edição está sendo preparada. Volte em instantes.</p>
    ) : (
      <>
        <section class="mt-6">
          <h2 class="sr-only">Principais notícias</h2>
          <StoryList stories={edition.home} featureFirst />
        </section>

        {
          latestEditorial && (
            <a
              href={`/editorial/${latestEditorial.date}/`}
              class="group mt-8 block rounded-lg border border-sky-200 bg-sky-50/60 p-4 transition-colors hover:border-sky-300 hover:bg-sky-50 dark:border-sky-900 dark:bg-sky-950/40 dark:hover:border-sky-800"
            >
              <p class="text-xs font-medium uppercase tracking-wide text-sky-700 dark:text-sky-400">
                Panorama do dia · Análise
              </p>
              <h2 class="mt-1 font-serif text-xl font-bold leading-snug group-hover:underline">
                {latestEditorial.titulo}
              </h2>
              <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">{latestEditorial.linhaFina}</p>
              <span class="mt-2 inline-block text-sm font-medium text-sky-700 group-hover:underline dark:text-sky-400">
                Ler a análise →
              </span>
            </a>
          )
        }

        <AdSlot />

        {CATEGORIES.map((cat) => <CategorySection category={cat} stories={edition.categorias[cat]} />)}

        <Newsletter />

        {
          hotTopics.length > 0 && (
            <section class="mt-10 border-t border-neutral-200 pt-6 dark:border-neutral-800">
              <h2 class="font-serif text-lg font-bold">Temas em alta</h2>
              <div class="mt-3 flex flex-wrap gap-2 text-sm">
                {hotTopics.map((t) => (
                  <a
                    href={`/tema/${t.slug}/`}
                    class="rounded-full border border-neutral-200 px-3 py-1 text-neutral-700 hover:border-sky-300 hover:text-sky-700 dark:border-neutral-700 dark:text-neutral-300 dark:hover:text-sky-400"
                  >
                    {t.label}
                  </a>
                ))}
              </div>
            </section>
          )
        }
      </>
    )
  }
</Layout>
