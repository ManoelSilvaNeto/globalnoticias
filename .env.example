# Chave da Groq (console.groq.com) — free tier, sem cartão.
# Modelo padrão: openai/gpt-oss-20b (structured outputs estritos = JSON garantido).
# Sem a chave, o pipeline ainda roda usando a descrição do RSS como resumo (fallback).
GROQ_API_KEY=

# Opcional: troca o modelo da Groq. Para JSON 100% confiável use um modelo com
# structured outputs estritos (openai/gpt-oss-20b ou openai/gpt-oss-120b). Modelos
# sem isso (ex.: llama-3.3-70b-versatile) caem no json_object best-effort.
# GROQ_MODEL=openai/gpt-oss-20b

# Opcional: URL canônica do site (sitemap/canonical). Default no astro.config.
# SITE_URL=https://noticias.globalnote.com.br
